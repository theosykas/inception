export LOGO_WHALE

init_create_dir:
	mkdir -p $(VOLUME_DB) $(WORDPRESS_VOLUME)

build: init_create_dir
## -p check if dir exist
	@echo "$(GREEN)creating volume and build containeur$(RESET)"
	$(COMPOSE) build
	@echo "$(BLUE)$$LOGO_WHALE$(RESET)"

up: init_create_dir
	$(COMPOSE) up -d

down:
	$(COMPOSE) down -v

ps:
	@echo "$(GREEN)Listing active containeurs...$(RESET)"
	$(COMPOSE) ps

logs:
	@echo "$(GREEN) Display logs$(RESET)"
	$(COMPOSE) logs

fclean: down
	@echo "$(RED)Removing all physical data from /home/thsykas/data...$(RESET)"
	sudo rm -rf $(VOLUME_DB) $(WORDPRESS_VOLUME)

.PHONY: up down build logs